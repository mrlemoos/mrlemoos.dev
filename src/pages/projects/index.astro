---
export const prerender = true;

import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import {
  projectStatusLabel,
  projects,
  type ProjectStatus,
} from "@/lib/data/projects";
import { buildPageMeta } from "@/lib/seo";
import { cn, projectCard, projectStatusBadge, textLink } from "@/lib/css";

const site = Astro.site!;
const siteOrigin = site.origin;
const projectsUrl = new URL("/projects", site).href;

const statusTone: Record<ProjectStatus, string> = {
  live: "project-status-live",
  beta: "project-status-beta",
  building: "project-status-building",
};

const meta = buildPageMeta(site, {
  title: "Projects | Leonardo Lemos",
  description:
    "Side projects and products by Leonardo Lemos — plan/ria, Grabkit, and Nota.",
  keywords: [
    "Leonardo Lemos projects",
    "Grabkit",
    "Nota",
    "plan/ria",
    "open source",
    "frontend",
  ],
  structuredData: {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebPage",
        "@id": `${projectsUrl}#webpage`,
        url: projectsUrl,
        name: "Projects | Leonardo Lemos",
        description:
          "Side projects and products by Leonardo Lemos — plan/ria, Grabkit, and Nota.",
        isPartOf: { "@id": `${siteOrigin}/#website` },
        breadcrumb: { "@id": `${projectsUrl}#breadcrumb` },
      },
      {
        "@type": "BreadcrumbList",
        "@id": `${projectsUrl}#breadcrumb`,
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: siteOrigin,
          },
          {
            "@type": "ListItem",
            position: 2,
            name: "Projects",
            item: projectsUrl,
          },
        ],
      },
      {
        "@type": "ItemList",
        "@id": `${projectsUrl}#itemlist`,
        numberOfItems: projects.length,
        itemListElement: projects.map((project, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: project.name,
          url: project.url,
        })),
      },
    ],
  },
});
---

<BaseLayout {...meta}>
  <div class="mx-auto max-w-4xl px-4 py-8 md:py-12">
    <Breadcrumb
      items={[{ label: "Home", href: "/" }, { label: "Projects" }]}
    />

    <header class="projects-intro mb-12 md:mb-16">
      <p
        class="mb-4 font-mono text-[0.65rem] font-medium uppercase tracking-[0.28em] text-muted-foreground"
      >
        Selected work
      </p>
      <h1
        class="font-heading text-4xl tracking-tight text-foreground md:text-5xl"
      >
        Projects
      </h1>
      <p class="mt-5 max-w-2xl text-pretty text-base leading-relaxed text-muted-foreground md:text-lg">
        Products and tools I build outside the day job — from fintech experiments
        to open-source libraries and native Mac software.
      </p>
    </header>

    <div class="flex flex-col gap-6">
      {
        projects.map((project, index) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class={cn(
              projectCard,
              index === 0 && "project-card-featured md:p-8"
            )}
          >
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <div class="mb-3 flex flex-wrap items-center gap-3">
                  <span
                    class="font-mono text-xs tabular-nums text-muted-foreground"
                    aria-hidden="true"
                  >
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <span
                    class={cn(
                      projectStatusBadge,
                      statusTone[project.status]
                    )}
                  >
                    {projectStatusLabel[project.status]}
                  </span>
                </div>
                <h2 class="font-heading text-2xl tracking-tight text-foreground transition-colors duration-200 group-hover:text-foreground md:text-3xl">
                  {project.name}
                </h2>
                <p class="mt-1 font-mono text-sm text-muted-foreground">
                  {new URL(project.url).hostname}
                  <span aria-hidden="true" class="ml-1.5 text-xs">↗</span>
                </p>
              </div>
            </div>

            <p class="mt-5 max-w-2xl text-pretty leading-relaxed text-muted-foreground">
              {project.description}
            </p>

            <ul
              class="mt-5 flex flex-wrap gap-2"
              aria-label={`${project.name} tags`}
            >
              {project.tags.map((tag) => (
                <li>
                  <span class="project-tag rounded-full border border-border bg-background/50 px-2.5 py-1 font-mono text-[0.65rem] uppercase tracking-wider text-muted-foreground">
                    {tag}
                  </span>
                </li>
              ))}
            </ul>
          </a>
        ))
      }
    </div>

    <p class="mt-10 text-sm text-muted-foreground">
      More on
      <a href="/" class={cn(textLink, "ml-1")}>home</a>
      or
      <a href="/blog" class={cn(textLink, "ml-1")}>the blog</a>.
    </p>
  </div>
</BaseLayout>
