---
export const prerender = true;

import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildPageMeta } from "@/lib/seo";
import { formatDate } from "@/lib/date";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { blogCardArticle, blogCardTitle, cn } from "@/lib/css";

const site = Astro.site!;
const siteOrigin = site.origin;
const blogUrl = new URL("/blog", site).href;

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const meta = buildPageMeta(site, {
  title: "Blog | Leonardo Lemos",
  description:
    "Articles on frontend engineering, design systems and AI, Tailwind CSS, analytics, and shipping resilient web software—by Leonardo Lemos.",
  keywords: [
    "frontend blog",
    "design systems",
    "Tailwind CSS",
    "Astro",
    "software engineering",
    "Leonardo Lemos",
  ],
  structuredData: {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebPage",
        "@id": `${blogUrl}#webpage`,
        url: blogUrl,
        name: "Blog | Leonardo Lemos",
        description:
          "Articles on frontend engineering, design systems, Tailwind CSS, analytics, and resilient web software.",
        isPartOf: { "@id": `${siteOrigin}/#website` },
        breadcrumb: { "@id": `${blogUrl}#breadcrumb` },
      },
      {
        "@type": "BreadcrumbList",
        "@id": `${blogUrl}#breadcrumb`,
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: siteOrigin,
          },
          {
            "@type": "ListItem",
            position: 2,
            name: "Blog",
            item: blogUrl,
          },
        ],
      },
      {
        "@type": "Blog",
        "@id": `${blogUrl}#blog`,
        url: blogUrl,
        name: "Leonardo Lemos — blog",
        description:
          "Frontend engineering, design systems, and practical notes on building for the web.",
        publisher: { "@id": `${siteOrigin}/#person` },
        blogPost: posts.map((p) => ({
          "@type": "BlogPosting",
          headline: p.data.title,
          url: new URL(`/blog/${p.id}`, site).href,
        })),
      },
      {
        "@type": "ItemList",
        "@id": `${blogUrl}#itemlist`,
        numberOfItems: posts.length,
        itemListElement: posts.map((p, i) => ({
          "@type": "ListItem",
          position: i + 1,
          name: p.data.title,
          url: new URL(`/blog/${p.id}`, site).href,
        })),
      },
    ],
  },
});
---

<BaseLayout {...meta}>
  <div class="mx-auto max-w-4xl px-4 py-8 md:py-12">
    <Breadcrumb
      items={[{ label: "Home", href: "/" }, { label: "Blog" }]}
    />
    <h1 class="mb-10 font-heading text-4xl tracking-tight text-foreground md:text-5xl">
      Blog posts
    </h1>
    <div class="flex flex-col gap-5">
      {
        posts.map(({ id, data: { title, date, description } }) => (
          <a
            href={`/blog/${id}`}
            class={cn(
              blogCardArticle,
              "block text-left text-inherit no-underline",
              "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
            )}
          >
            <h2 class={cn(blogCardTitle, "mb-2 text-2xl font-normal md:text-3xl")}>
              {title}
            </h2>
            <p class="mb-2 text-sm text-muted-foreground">{formatDate(date)}</p>
            <p class="text-muted-foreground">{description}</p>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>
