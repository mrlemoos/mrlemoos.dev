---
export const prerender = true;

import "katex/dist/katex.min.css";
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  buildPageMeta,
  ogImageForPost,
  SITE_BRAND_NAME,
  titleWithBrand,
} from "@/lib/seo";
import { formatDate } from "@/lib/date";
import {
  EMAIL_URL,
  GITHUB_URL,
  LINKEDIN_URL,
  X_URL,
} from "@/lib/constants";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { cn, socialNavLink, socialNavRow, textLink } from "@/lib/css";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

const { slug } = Astro.params;
const post = await getEntry("blog", slug!);

if (!post) {
  return Astro.redirect("/404");
}

const { Content } = await render(post);
const site = Astro.site!;
const publishedISO = post.data.date.toISOString();
const modifiedISO = (post.data.updated ?? post.data.date).toISOString();
const pageUrl = new URL(`/blog/${slug}`, site).href;
const ogImageHref = ogImageForPost(site, post.data.title);

const genericTags = new Set(["blog", "personal"]);
const articleSection =
  post.data.tags.find((t) => !genericTags.has(t.toLowerCase())) ??
  post.data.tags[0];

const wordCount = post.body
  ? post.body.trim().split(/\s+/).filter(Boolean).length
  : undefined;

const blogPosting: Record<string, unknown> = {
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: publishedISO,
  dateModified: modifiedISO,
  image: ogImageHref,
  url: pageUrl,
  articleSection,
  author: {
    "@type": "Person",
    name: SITE_BRAND_NAME,
    url: site.origin,
  },
  publisher: {
    "@type": "Person",
    name: SITE_BRAND_NAME,
    url: site.origin,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": pageUrl,
  },
};
if (wordCount !== undefined) {
  blogPosting.wordCount = wordCount;
}

const meta = buildPageMeta(site, {
  title: titleWithBrand(post.data.title),
  description: post.data.description,
  keywords: post.data.tags,
  ogImage: ogImageHref,
  articlePublishedTime: publishedISO,
  articleModifiedTime: modifiedISO,
  structuredData: {
    "@context": "https://schema.org",
    "@graph": [
      blogPosting,
      {
        "@type": "BreadcrumbList",
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: site.origin,
          },
          {
            "@type": "ListItem",
            position: 2,
            name: "Blog",
            item: new URL("/blog", site).href,
          },
          {
            "@type": "ListItem",
            position: 3,
            name: post.data.title,
            item: pageUrl,
          },
        ],
      },
    ],
  },
});
---

<BaseLayout {...meta}>
  <article
    class="mx-auto max-w-4xl px-4 py-8 md:py-12 lg:mt-[12dvh]"
  >
    <Breadcrumb
      items={[
        { label: "Home", href: "/" },
        { label: "Blog", href: "/blog" },
        { label: post.data.title },
      ]}
    />
    <h1 class="mb-3 text-center font-heading text-4xl font-normal leading-tight tracking-tight text-foreground md:text-5xl">
      {post.data.title}
    </h1>
    <p class="mb-10 text-center text-muted-foreground">
      {
        post.data.updated &&
        post.data.updated.getTime() !== post.data.date.getTime()
          ? `Published ${formatDate(post.data.date)} · Updated ${formatDate(post.data.updated)}`
          : `Published on ${formatDate(post.data.date)}`
      }
    </p>
    <p class="text-muted-foreground">Leo writes:</p>
    <div
      class="prose prose-lg dark:prose-invert mt-4 max-w-none text-foreground prose-pre:bg-transparent prose-pre:p-0 prose-a:text-foreground prose-a:underline prose-a:decoration-zinc-400/70 prose-a:underline-offset-4 hover:prose-a:decoration-foreground"
    >
      <Content />
    </div>
    <span class="mt-6 flex flex-col gap-1 pt-6 text-muted-foreground">
      To everyone in this kingdom and beyond,
      <br />
      Leo
    </span>
    <div
      class="mt-12 flex flex-col gap-4 border-t border-border pt-8"
    >
      <a href="/blog" class={textLink}>
        More posts on the blog
      </a>
      <a href="/" class={textLink}>
        Liked it? Hated it and want to shout at me? Learn more about me here.
      </a>
      <div class="flex flex-col gap-2">
        <span class="text-muted-foreground">Connect with me</span>
        <div class={cn(socialNavRow, "justify-start")}>
          <a
            href={LINKEDIN_URL}
            target="_blank"
            rel="noopener noreferrer"
            class={socialNavLink}>LinkedIn</a
          >
          <a href={X_URL} target="_blank" rel="noopener noreferrer" class={socialNavLink}
            >X</a
          >
          <a
            href={GITHUB_URL}
            target="_blank"
            rel="noopener noreferrer"
            class={socialNavLink}>GitHub</a
          >
          <a href={EMAIL_URL} class={socialNavLink}>Email</a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
