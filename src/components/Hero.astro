---
import { GITHUB_URL, LINKEDIN_URL, X_URL } from "@/lib/constants";
import { socialNavLink, socialNavRow } from "@/lib/css";
import { HERO_TAGLINE } from "@/lib/seo";
---

<section
  class="flex min-h-[72vh] flex-col justify-end pb-4 pt-16 md:min-h-[78vh] md:pb-8 md:pt-20"
>
  <div class="mx-auto w-full max-w-3xl text-center">
    <h1
      class="hero-animate font-heading text-[clamp(2.75rem,8vw,5.5rem)] font-normal leading-[1.05] tracking-[-0.03em] text-foreground"
    >
      Leonardo Lemos
    </h1>
    <p
      class="hero-animate hero-animate-delay-1 mx-auto mt-6 max-w-xl text-pretty text-base leading-relaxed text-muted-foreground md:text-lg"
    >
      {HERO_TAGLINE}
    </p>
    <div
      class="hero-animate hero-animate-delay-2 mt-10 flex flex-col items-center gap-3"
    >
      <span class="text-sm text-muted-foreground">Connect with me</span>
      <div class={socialNavRow}>
        <a href={GITHUB_URL} class={socialNavLink}>GitHub</a>
        <a href={X_URL} class={socialNavLink}>X</a>
        <a href={LINKEDIN_URL} class={socialNavLink}>LinkedIn</a>
      </div>
    </div>
  </div>
</section>
