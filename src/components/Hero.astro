---
import { GITHUB_URL, LINKEDIN_URL, X_URL } from "@/lib/constants";
import { socialNavLink, socialNavRow } from "@/lib/css";
---

<section
  class="mb-24 flex min-h-[50vh] flex-col items-center justify-center"
>
  <h1 class="mb-2 text-2xl font-medium">Leonardo Lemos</h1>
  <p class="text-center text-gray-700 dark:text-gray-300">
    Frontend engineer, software architecture enthusiast, and open-source
    contributor.
  </p>
  <div class="flex flex-col items-center justify-center gap-2 pt-5">
    <span class="text-gray-600 dark:text-gray-400">Connect with me:</span>
    <div class={socialNavRow}>
      <a href={GITHUB_URL} class={socialNavLink}>GitHub</a>
      <a href={X_URL} class={socialNavLink}>X</a>
      <a href={LINKEDIN_URL} class={socialNavLink}>LinkedIn</a>
    </div>
  </div>
</section>
