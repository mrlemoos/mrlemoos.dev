---
import { experiences } from "@/lib/data/experience";
import { textLink } from "@/lib/css";
---

<section class="my-24 border-t border-border pt-16">
  <h2 class="mb-10 font-heading text-2xl tracking-tight text-foreground md:text-3xl">
    Experience
  </h2>
  <div>
    {
      experiences.map(
        ({ company, companyURL, title, period, description, skills }) => (
          <div class="mb-12 last:mb-0">
            <div class="mb-2 flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
              <h3 class="font-heading text-xl font-normal tracking-tight text-foreground">
                {title}
              </h3>
              <span class="text-sm text-muted-foreground">{period}</span>
            </div>
            <a
              href={companyURL}
              target="_blank"
              rel="noopener noreferrer"
              class={textLink}
            >
              {company}
            </a>
            {description.length > 0 && (
              <ul class="mb-3 mt-3 list-inside list-disc space-y-1.5 text-muted-foreground">
                {description.map((line) => (
                  <li>{line}</li>
                ))}
              </ul>
            )}
            <div class="flex flex-col gap-1">
              <span class="text-sm text-muted-foreground">Skills</span>
              <span class="text-sm text-muted-foreground">{skills.join(", ")}</span>
            </div>
          </div>
        )
      )
    }
  </div>
</section>
