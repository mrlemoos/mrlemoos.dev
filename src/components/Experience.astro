---
import { experiences } from "@/lib/data/experience";
import { cn, contentPanel, sectionTitle, textLink } from "@/lib/css";
---

<section class="section-fade-top my-24 pt-20 md:pt-24">
  <h2 class={cn(sectionTitle, "mb-10")}>Experience</h2>
  <div class="flex flex-col gap-4">
    {
      experiences.map(
        ({ company, companyURL, title, period, description, skills }) => (
          <article class={cn(contentPanel, "p-5 md:p-6")}>
            <div class="mb-2 flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
              <h3 class="font-heading text-xl font-normal leading-[1.15] tracking-[-0.02em] text-foreground">
                {title}
              </h3>
              <span class="text-sm tracking-[0.01em] text-muted-foreground">{period}</span>
            </div>
            <a
              href={companyURL}
              target="_blank"
              rel="noopener noreferrer"
              class={textLink}
            >
              {company}
            </a>
            {description.length > 0 && (
              <ul class="mb-3 mt-3 list-inside list-disc space-y-1.5 leading-[1.6] text-muted-foreground">
                {description.map((line) => (
                  <li>{line}</li>
                ))}
              </ul>
            )}
            <div class="flex flex-col gap-2">
              <span class="font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-foreground">
                Skills
              </span>
              <p class="text-sm leading-[1.6] tracking-[0.01em] text-muted-foreground">
                {skills.join(", ")}
              </p>
            </div>
          </article>
        )
      )
    }
  </div>
</section>
