---
import { experiences } from "@/lib/data/experience";
---

<section class="my-24">
  <h2 class="mb-6 text-lg font-bold">Experience</h2>
  <div>
    {
      experiences.map(
        ({ company, companyURL, title, period, description, skills }) => (
          <div class="mb-8">
            <div class="mb-1 flex items-baseline justify-between">
              <h3 class="font-medium">{title}</h3>
              <span class="text-sm text-gray-600 dark:text-gray-400">{period}</span>
            </div>
            <a
              href={companyURL}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-md pb-2.5 text-gray-700 underline-offset-2 transition-colors hover:text-gray-900 hover:underline dark:text-gray-300 dark:hover:text-gray-100"
            >
              {company}
            </a>
            <ul class="mb-2 list-inside list-disc text-gray-700 dark:text-gray-400">
              {description.map((line) => (
                <li class="mb-1">{line}</li>
              ))}
            </ul>
            <div class="flex flex-col gap-1.5">
              <span class="text-gray-600 dark:text-gray-400">Skills:</span>
              <span class="text-sm text-gray-600 dark:text-gray-400">{skills.join(", ")}</span>
            </div>
          </div>
        )
      )
    }
  </div>
</section>
