---
import { getCollection } from "astro:content";
import { formatDate } from "@/lib/date";

const allPosts = await getCollection("blog");
const posts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<section>
  <h2 class="mb-6 text-lg font-bold">Latest Posts</h2>
  <div>
    {
      posts.map((post) => (
        <article class="mb-8">
          <a href={`/blog/${post.id}`}>
            <h3 class="mb-1 font-semibold hover:underline">{post.data.title}</h3>
          </a>
          <p class="mb-1 text-sm text-gray-600 dark:text-gray-400">
            {formatDate(post.data.date)}
          </p>
          <p class="text-gray-700 dark:text-gray-400">{post.data.description}</p>
        </article>
      ))
    }
    <a
      href="/blog"
      class="inline-flex min-h-12 items-center text-sm text-gray-700 underline-offset-2 hover:text-gray-900 hover:underline dark:text-gray-300 dark:hover:text-gray-100"
    >
      View all posts →
    </a>
  </div>
</section>
