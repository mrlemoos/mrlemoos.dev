---
import { getCollection } from "astro:content";
import { formatDate } from "@/lib/date";
import { blogCardArticle, blogCardTitle, cn, textLink } from "@/lib/css";

const allPosts = await getCollection("blog");
const posts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<section class="border-t border-border pt-16">
  <h2 class="mb-8 font-heading text-2xl tracking-tight text-foreground md:text-3xl">
    Latest posts
  </h2>
  <div class="flex flex-col gap-5">
    {
      posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class={cn(
            blogCardArticle,
            "block text-left text-inherit no-underline",
            "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
          )}
        >
          <h3 class={cn(blogCardTitle, "mb-2 font-normal")}>{post.data.title}</h3>
          <p class="mb-2 text-sm text-muted-foreground">
            {formatDate(post.data.date)}
          </p>
          <p class="text-muted-foreground">{post.data.description}</p>
        </a>
      ))
    }
    <a href="/blog" class={cn(textLink, "inline-flex min-h-12 items-center text-sm font-medium")}>
      View all posts →
    </a>
  </div>
</section>
