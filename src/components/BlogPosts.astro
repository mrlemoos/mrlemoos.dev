---
import { getCollection } from "astro:content";
import { formatDate } from "@/lib/date";
import { blogCardArticle, blogCardTitle, cn, sectionTitle, textLink } from "@/lib/css";

const allPosts = await getCollection("blog");
const posts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<section class="section-fade-top pt-20 md:pt-24">
  <h2 class={cn(sectionTitle, "mb-8")}>Latest posts</h2>
  <div class="flex flex-col gap-4">
    {
      posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class={cn(
            blogCardArticle,
            "block text-left text-inherit no-underline",
            "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
          )}
        >
          <h3 class={cn(blogCardTitle, "mb-2 font-normal leading-[1.2] tracking-[-0.02em]")}>{post.data.title}</h3>
          <p class="mb-2 text-sm tracking-[0.01em] text-muted-foreground">
            {formatDate(post.data.date)}
          </p>
          <p class="text-muted-foreground">{post.data.description}</p>
        </a>
      ))
    }
    <a href="/blog" class={cn(textLink, "inline-flex min-h-12 items-center text-sm font-medium")}>
      View all posts →
    </a>
  </div>
</section>
