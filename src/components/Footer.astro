---
import {
  EMAIL_URL,
  GITHUB_URL,
  LINKEDIN_URL,
  X_URL,
} from "@/lib/constants";
import { cn, socialNavLink, socialNavRow } from "@/lib/css";

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-card/30 py-10 dark:bg-card/20">
  <div class="container mx-auto px-4">
    <div
      class="flex flex-col items-center gap-5 text-sm text-muted-foreground"
    >
      <div class={cn(socialNavRow, "justify-center")}>
        <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class={socialNavLink}
          >GitHub</a
        >
        <a href={X_URL} target="_blank" rel="noopener noreferrer" class={socialNavLink}
          >X</a
        >
        <a
          href={LINKEDIN_URL}
          target="_blank"
          rel="noopener noreferrer"
          class={socialNavLink}>LinkedIn</a
        >
        <a href={EMAIL_URL} class={socialNavLink}>Email</a>
      </div>
      <div class="text-center text-muted-foreground">
        Copyright {currentYear} © Leonardo Lemos. All rights reserved.
      </div>
    </div>
  </div>
</footer>
